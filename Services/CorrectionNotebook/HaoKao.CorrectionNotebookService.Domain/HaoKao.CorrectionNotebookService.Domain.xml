        <member name="M:HaoKao.CorrectionNotebookService.Domain.Entities.Question.MyRegex">
            <remarks>
            Pattern:<br/>
            <code>答案[:：]\\s*(?&lt;answer&gt;.+?)\\s*解析[:：]\\s*(?&lt;analysis&gt;[\\s\\S]+)</code><br/>
            Explanation:<br/>
            <code>
            ○ Match the string "答案".<br/>
            ○ Match a character in the set [:\uFF1A].<br/>
            ○ Match a whitespace character greedily any number of times.<br/>
            ○ "answer" capture group.<br/>
                ○ Match a character other than '\n' lazily at least once.<br/>
            ○ Match a whitespace character atomically any number of times.<br/>
            ○ Match the string "解析".<br/>
            ○ Match a character in the set [:\uFF1A].<br/>
            ○ Match a whitespace character greedily any number of times.<br/>
            ○ "analysis" capture group.<br/>
                ○ Match any character atomically at least once.<br/>
            </code>
            </remarks>
        </member>
